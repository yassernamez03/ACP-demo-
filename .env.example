# Optional API keys — only needed if you switch an agent from Ollama to a hosted provider.
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# Keep CrewAI tracing OFF: when enabled it can show an interactive prompt that blocks the server.
CREWAI_TRACING_ENABLED=false

# Optional: override the default Ollama model / endpoint without editing the server files.
# For weaker machines, set OLLAMA_MODEL=ollama_chat/qwen2.5:7b
# OLLAMA_MODEL=ollama_chat/qwen2.5:14b
# OLLAMA_BASE_URL=http://localhost:11434
